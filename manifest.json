{
  "manifest_version": 3,
  "name": "Anti-Racism Content Reporter",
  "version": "1.0",
  "description": "Scans social media comments, flags hate speech using local rules or an LLM API, and facilitates quick reporting.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["demo.html", "styles.css", "content.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
